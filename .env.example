# Copy this file to .env and fill every value before starting Compass.

# --- Image pins ---
# Replace these with fixed tags you have tested before running in production.
OLLAMA_IMAGE=ollama/ollama:replace-with-tested-tag
POSTGRES_IMAGE=postgres:17-alpine
FIREFLY_IMAGE=fireflyiii/core:replace-with-tested-tag
VIKUNJA_IMAGE=vikunja/vikunja:replace-with-tested-tag
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:replace-with-tested-tag
PIPELINES_IMAGE=ghcr.io/open-webui/pipelines:replace-with-tested-tag

# --- Host ports ---
HOST_BIND=127.0.0.1
OLLAMA_PORT=11434
FIREFLY_PORT=24010
VIKUNJA_PORT=24030
OPEN_WEBUI_PORT=3000

# --- Locale ---
TZ=Asia/Kolkata

# --- Telegram ---
TELEGRAM_TOKEN=replace-with-botfather-token
TELEGRAM_ALLOWED_USER_IDS=123456789
# Optional. By default the bot only replies in private chats.
TELEGRAM_ALLOWED_CHAT_IDS=

# --- Firefly III ---
# Generate with the command in docs/INSTALL.md after setting FIREFLY_IMAGE.
FIREFLY_APP_KEY=base64:replace-with-generated-app-key
FIREFLY_DB_PASSWORD=replace-with-strong-password
FIREFLY_APP_URL=http://localhost:24010
FIREFLY_DEFAULT_LANGUAGE=en_US
FIREFLY_DEFAULT_LOCALE=en_IN
FIREFLY_TRUSTED_PROXIES=
FIREFLY_TOKEN=replace-with-firefly-personal-access-token

# --- Vikunja ---
VIKUNJA_DB_PASSWORD=replace-with-strong-password
VIKUNJA_PUBLIC_URL=http://localhost:24030
VIKUNJA_ENABLE_REGISTRATION=false
VIKUNJA_TOKEN=replace-with-vikunja-api-token

# --- Ollama / local LLM ---
OLLAMA_MODEL=gemma4:e4b
OLLAMA_KEEP_ALIVE=-1
OLLAMA_NUM_CTX=4096
OLLAMA_WARMUP_TIMEOUT=30

# --- Open WebUI / pipelines ---
PIPELINES_API_KEY=replace-with-random-api-key
