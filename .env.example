# Copy this file to .env and fill every value before starting Compass.
# Nothing in this file is optional unless marked so.

# --- Image pins ---
# Replace these with fixed tags you have tested before running in production.
# Browse tags on Docker Hub / ghcr.io for each project.
OLLAMA_IMAGE=ollama/ollama:replace-with-tested-tag
POSTGRES_IMAGE=postgres:17-alpine
FIREFLY_IMAGE=fireflyiii/core:replace-with-tested-tag
VIKUNJA_IMAGE=vikunja/vikunja:replace-with-tested-tag
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:replace-with-tested-tag
PIPELINES_IMAGE=ghcr.io/open-webui/pipelines:replace-with-tested-tag

# --- Host ports ---
# HOST_BIND is the address web ports bind to. Keep 127.0.0.1 unless the host
# is protected by a firewall, VPN, or reverse proxy.
HOST_BIND=127.0.0.1
OLLAMA_PORT=11434
FIREFLY_PORT=24010
VIKUNJA_PORT=24030
OPEN_WEBUI_PORT=3000

# --- Locale ---
# IANA timezone used by all services and for scheduled digests/reminders.
TZ=Asia/Kolkata
# Deployment currency (ISO 4217 code: INR, USD, EUR, GBP, ...). One currency
# for the whole instance; controls display symbols, what the LLM is told to
# emit, and the default currency configured in Firefly at install time.
CURRENCY=INR

# --- Telegram ---
# Bot token from @BotFather on Telegram.
TELEGRAM_TOKEN=replace-with-botfather-token
# Comma-separated numeric Telegram user IDs allowed to use the bot.
# Get yours from @userinfobot on Telegram.
TELEGRAM_ALLOWED_USER_IDS=123456789
# Optional group-chat allowlist. By default the bot only replies in private chats.
TELEGRAM_ALLOWED_CHAT_IDS=

# --- Schedules (bot timezone, HH:MM) ---
# Daily task digest. Leave empty to disable.
DIGEST_TIME=11:00
# Optional comma-separated "log your expenses" nudges, e.g. 12:00,17:00,22:00.
# Empty disables them.
REMINDER_TIMES=
# How long (seconds) an unconfirmed transaction/todo card stays alive.
PENDING_TIMEOUT_SECONDS=600

# --- Firefly III ---
# Generate with: docker run --rm "$FIREFLY_IMAGE" php artisan key:generate --show
FIREFLY_APP_KEY=base64:replace-with-generated-app-key
FIREFLY_DB_PASSWORD=replace-with-strong-password
# URL you will open Firefly at in the browser.
FIREFLY_APP_URL=http://localhost:24010
FIREFLY_DEFAULT_LANGUAGE=en_US
FIREFLY_DEFAULT_LOCALE=en_IN
# Only set if Firefly sits behind a reverse proxy you control.
FIREFLY_TRUSTED_PROXIES=
# Personal access token: Firefly web UI -> Options -> Profile -> OAuth.
FIREFLY_TOKEN=replace-with-firefly-personal-access-token

# --- Vikunja ---
VIKUNJA_DB_PASSWORD=replace-with-strong-password
# URL you will open Vikunja at in the browser.
VIKUNJA_PUBLIC_URL=http://localhost:24030
VIKUNJA_ENABLE_REGISTRATION=false
# API token: Vikunja web UI -> Settings -> API Tokens.
VIKUNJA_TOKEN=replace-with-vikunja-api-token

# --- Ollama / local LLM ---
# Any Ollama model that reliably emits JSON. Pull it after starting Ollama:
#   docker compose exec ollama ollama pull <model>
OLLAMA_MODEL=gemma4:e4b
# -1 keeps the model loaded in memory permanently.
OLLAMA_KEEP_ALIVE=-1
OLLAMA_NUM_CTX=4096
# Seconds allowed for the one-time prompt warmup at bot startup.
OLLAMA_WARMUP_TIMEOUT=30

# --- Open WebUI / pipelines (optional, profile ai-webui) ---
# Any long random string; shared between Open WebUI and the Pipelines service.
PIPELINES_API_KEY=replace-with-random-api-key
