# Local bot-only development example. For Docker Compose, use ../.env.example.

# Firefly III base URL and personal access token
# (Firefly web UI -> Options -> Profile -> OAuth).
FIREFLY_URL=http://localhost:24010
FIREFLY_TOKEN=replace-with-firefly-personal-access-token

# Ollama endpoint and the model used for parsing.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# Telegram bot token from @BotFather; user IDs from @userinfobot.
TELEGRAM_TOKEN=replace-with-botfather-token
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_ALLOWED_CHAT_IDS=

# Vikunja base URL and API token (Vikunja web UI -> Settings -> API Tokens).
VIKUNJA_URL=http://localhost:24030
VIKUNJA_TOKEN=replace-with-vikunja-api-token

# Where receipt files are staged before upload.
ATTACHMENTS_DIR=./attachments

# Daily digest time (HH:MM, empty disables) and optional reminder nudges.
DIGEST_TIME=11:00
REMINDER_TIMES=
